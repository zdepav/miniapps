{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "authors": {
      "type": "array",
      "description": "List of authors",
      "items": {
        "type": "string",
        "description": "Author's full name"
      }
    },
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "assets": {
      "type": "array",
      "description": "List of assets given as paths relative to the 'assets' directory",
      "items": {
        "type": "string",
        "description": "Relative asset path",
        "pattern": "^([-_a-zA-Z0-9]+/)*[-_a-zA-Z0-9]+\\.[a-z0-9]+$"
      }
    },
    "type": {
      "description": "Project type, either 'game' or 'app'",
      "enum": ["game", "app"]
    },
    "created": {
      "type": "string",
      "description": "Project creation date",
      "pattern": "^[0-9]{4}(-[0-9]{2}){2}(T[0-9]{2}(:[0-9]{2}){2}(\\.[0-9]+)?(Z|[-+][0-9]{2}(:[0-9]{2})?)?)?$"
    }
  },
  "required": ["name", "type", "created"]
}
